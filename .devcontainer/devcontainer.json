{
  "name": "nuxt-dev",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "features": {},
  "postCreateCommand": "npm install -g pnpm && pnpm install --frozen-lockfile",
  "forwardPorts": [3000],
  "containerEnv": {
    "CHOKIDAR_USEPOLLING": "true" // Docker/devcontainer環境でのHMR安定化
  },
  "customizations": {
    "vscode": {
      "extensions": ["Vue.volar", "dbaeumer.vscode-eslint"]
    }
  }
}
